# .32 Convertion Of Text
def extract_genres(text):
    # Converting String Into list
    actual_list = ast.literal_eval(text)
    
    # .33 Keeping only The Name from Every Element
    names_only = [item['name'] for item in actual_list]
    
    # .34 It Joins them in a text Separated with Commas
    return ", ".join(names_only)

# .35 Application In The Function with.apply()
